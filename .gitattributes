# ==========================================
# RaktaSetu NOOR - Git Attributes
# ==========================================

# Set default behavior to automatically handle line endings
* text=auto

# Enforce LF (Unix-style) line endings on check-in for all source and configuration files
# This ensures cross-platform compatibility with Linux CI/CD runners and Docker containers
*.py       text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.ini      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.sh       text eol=lf
Dockerfile text eol=lf

# Enforce CRLF (Windows-style) line endings for Windows command scripts
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Denote binary files (do not normalize line endings)
*.png      -text
*.jpg      -text
*.jpeg     -text
*.gif      -text
*.ico      -text
*.pdf      -text
*.db       -text
*.sqlite   -text
*.sqlite3  -text
*.zip      -text
*.tar.gz   -text
*.tgz      -text
