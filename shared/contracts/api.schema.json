              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/grid/banks/{bank_id}/inventory": {
      "post": {
        "tags": [
          "RaktaGrid Optimization"
        ],
        "summary": "Sync Blood Bank Inventory Endpoint",
        "description": "Bulk upserts a blood bank's inventory using structured inputs,\nand invalidates the associated city's grid cache.",
        "operationId": "sync_blood_bank_inventory_endpoint_api_v1_grid_banks__bank_id__inventory_post",
        "parameters": [
          {
            "name": "bank_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Bank Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkInventoryUpsertSchema"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_str_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/chatbot/message": {
      "post": {
        "tags": [
          "Saathi Chatbot"
        ],
        "summary": "Handle Chatbot Message",
        "description": "Handles virtual coordination questions from guardians and donors.\nExtracts intents using standard regex pattern matching and returns DB-sourced replies.\n\nArgs:\n    payload (ChatbotMessageRequest): Input message content with optional patient/guardian contexts.\n    db (AsyncSession): Active async database session.\n\nReturns:\n    ApiResponse containing the ChatbotMessageResponse.",
        "operationId": "handle_chatbot_message_api_v1_chatbot_message_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatbotMessageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ChatbotMessageResponse_"
                }
              }
            }
          },
          "422": {
