                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/grid/matches/{match_id}/approve": {
      "post": {
        "tags": [
          "RaktaGrid Optimization"
        ],
        "summary": "Approve Transfer Match",
        "description": "Approves a blood transfer match, decrements available inventory units in the DB,\nand invalidates the city grid Redis cache.",
        "operationId": "approve_transfer_match_api_v1_grid_matches__match_id__approve_post",
        "parameters": [
          {
            "name": "match_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Match Id"
            }
          }
        ],
