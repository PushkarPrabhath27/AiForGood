{
  "openapi": "3.1.0",
  "info": {
    "title": "RaktaSetu NOOR",
    "description": "Empathetic, Predictive Blood Management Infrastructure for Thalassemia Care.",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "System Diagnostics"
        ],
        "summary": "Health Check",
        "description": "Returns standard 200 response mapping system availability status.\n\nReturns:\n    dict: Standard health envelope {\"status\": \"ok\", \"version\": \"1.0.0\"}",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/patients/{patient_id}/forecast": {
      "get": {
        "tags": [
          "Forecasting"
        ],
        "summary": "Get Patient Forecast",
        "description": "Retrieves or generates a clinical hemoglobin decay forecast and diagnostic alerts.\n\nChecks the Redis cache first for fresh predictions. On a cache miss, trains a\nFacebook Prophet model, computes sequential CUSUM alloimmunization, evaluates iron overload,\ncaches results, and updates patient prediction metadata.\n\nArgs:\n    patient_id: Unique identifier for the patient.\n    db: Async database session.\n    \nReturns:\n    ApiResponse containing the full clinical ForecastResponse.",
        "operationId": "get_patient_forecast_api_v1_patients__patient_id__forecast_get",
        "parameters": [
          {
            "name": "patient_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Patient Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ForecastResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/patients/{patient_id}/guardian-circle": {
      "get": {
        "tags": [
          "Guardians"
        ],
        "summary": "Get Patient Guardian Circle",
        "description": "Retrieves the clinical guardian circle details, continuous health scores,\nand current T-minus countdown mobilization states.\n\nArgs:\n    patient_id: Unique database identifier of the patient.\n    db: Async database session.\n    \nReturns:\n    ApiResponse containing the detailed GuardianCircleResponse.",
        "operationId": "get_patient_guardian_circle_api_v1_patients__patient_id__guardian_circle_get",
        "parameters": [
          {
            "name": "patient_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Patient Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_GuardianCircleResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/patients/{patient_id}/guardian-circle/mobilize": {
      "post": {
        "tags": [
          "Guardians"
        ],
        "summary": "Mobilize Guardian Circle",
        "description": "Manually activates the mobilization sequence for the patient's network.\nIf Suresh is pending, transitions his status to active and updates calculations.\n\nArgs:\n    patient_id: Unique database identifier of the patient.\n    db: Async database session.\n    \nReturns:\n    ApiResponse containing the updated MobilizationStatusResponse.",
        "operationId": "mobilize_guardian_circle_api_v1_patients__patient_id__guardian_circle_mobilize_post",
        "parameters": [
          {
            "name": "patient_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Patient Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_MobilizationStatusResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/patients/{patient_id}/alerts/{alert_id}/notify": {
      "post": {
        "tags": [
          "Alerts"
        ],
        "summary": "Notify Patient Alert",
        "description": "Triggers an empathetic notification to the patient's primary guardian regarding a clinical alert.\nFetches details, formats dynamic context, calls Claude, and dispatches via Twilio.\n\nArgs:\n    patient_id (str): Unique database identifier of the patient.\n    alert_id (str): Unique database identifier of the clinical alert.\n    db (AsyncSession): Active async database session.\n\nReturns:\n    ApiResponse containing the NotifyAlertResponse details.",
        "operationId": "notify_patient_alert_api_v1_patients__patient_id__alerts__alert_id__notify_post",
        "parameters": [
          {
            "name": "patient_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Patient Id"
            }
          },
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Alert Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_NotifyAlertResponse_"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/grid/city/{city_code}": {
      "get": {
        "tags": [
          "RaktaGrid Optimization"
        ],
        "summary": "Get City Grid",
        "description": "Retrieves the city-wide optimization grid including blood bank nodes,\ncalculated transfer matches, coverage percentages, and total inventory summaries.\nEnforces Redis caching with a 6-hour TTL.",
        "operationId": "get_city_grid_api_v1_grid_city__city_code__get",
        "parameters": [
          {
            "name": "city_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "City Code"
